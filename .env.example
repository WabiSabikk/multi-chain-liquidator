# Required
PRIVATE_KEY=0x...your_private_key...

# Mode: true = monitor only, false = execute liquidations
DRY_RUN=true

# Mantle (chain 5000) — requires Alchemy API key
MANTLE_RPC_URL=https://mantle-mainnet.g.alchemy.com/v2/YOUR_KEY
# MANTLE_LIQUIDATOR_CONTRACT=0xF2E6e7F255c46CC2353a8fD1D502f0c1920E1D43

# Ink (chain 57073) — free public RPC
# INK_RPC_URL=https://rpc-gel.inkonchain.com

# HyperEVM (chain 999) — free public RPC
# HYPEREVM_RPC_URL=https://rpc.hyperliquid.xyz/evm

# Telegram alerts (optional)
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# Logging: debug, info, warn, error
RUST_LOG=info
